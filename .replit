modules = ["nodejs-24", "python-3.11", "postgresql-16"]

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true
integrations = ["stripe:1.0.0", "google-calendar:1.0.0"]

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[[ports]]
localPort = 8080
externalPort = 8080

[[ports]]
localPort = 8081
externalPort = 80

[[ports]]
localPort = 8082
externalPort = 3001

[[ports]]
localPort = 8083
externalPort = 3002

[[ports]]
localPort = 19161
externalPort = 3000

[[ports]]
localPort = 24678
externalPort = 3003

[[ports]]
localPort = 25080
externalPort = 4200

[nix]
channel = "stable-25_05"

[userenv]

[userenv.shared]
VITE_GA_MEASUREMENT_ID = "G-KBKXSSC10Z"
SMTP_HOST = "mail.pamliecoconnect.com"
SMTP_PORT = "465"
SMTP_USER = "info@pamliecoconnect.com"

[userenv.production]
TELEGRAM_WEBHOOK_URL = "https://doma-website-builder.replit.app"
